{
    "name": "@fiduswriter/common",
    "version": "0.1.4",
    "description": "Fidus Writer-specific shared utilities and UI chrome",
    "repository": {
        "type": "git",
        "url": "ssh://git@codeberg.org/fiduswriter/fiduswriter-common-js.git"
    },
    "license": "AGPL-3.0",
    "author": "Johannes Wilm",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./common": "./dist/common/index.js",
        "./feedback": "./dist/feedback/index.js",
        "./menu": "./dist/menu/index.js",
        "./state_plugins": "./dist/state_plugins/index.js",
        "./state_plugins/contributor_input": "./dist/state_plugins/contributor_input/index.js",
        "./state_plugins/tag_input": "./dist/state_plugins/tag_input/index.js"
    },
    "files": [
        "dist/",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "fwtoolkit": "^0.1.4",
        "prosemirror-gapcursor": "^1.3.2",
        "prosemirror-history": "^1.3.2",
        "prosemirror-keymap": "^1.2.2",
        "prosemirror-model": "^1.25.0",
        "prosemirror-state": "^1.4.3",
        "prosemirror-view": "^1.38.1",
        "w3c-keyname": "2.2.8"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.6.0",
        "globals": "^15.15.0",
        "prettier": "^3.5.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0"
    }
}
